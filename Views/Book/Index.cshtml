    <script type="text/javascript">
        var searchby = '';
        function srchAutoComplete() {
            $("#keyword").unbind("autocomplete");
            $("#keyword").autocomplete({
                source: "/ajax/global_search.php?searchby=" + searchby,
                minLength: 2,
                select: function (event, ui) {
                    var getUrl = ui.item.id;
                    if (getUrl != '#') {
                        location.href = getUrl;
                    }
                },
                html: true,
                open: function (event, ui) {
                    $(".ui-autocomplete").css("z-index", 1000);
                }
            });
        }
        $(function () {

            $('form#form1 #searchby').change(function (e) {
                searchby = $(this).val();
                srchAutoComplete();

            })
            // searchby = $('form#form1 #searchby').val();

            srchAutoComplete();

        });
    </script>

