@using System.Configuration
@using System.Web.Mvc;

@{
    Layout = null;
    var action = ((string)ViewContext.RouteData.Values["Action"]).ToLower();

    var blogTitle = ConfigurationManager.AppSettings["BlogTitle"];
    var feedBurnerUrl = ConfigurationManager.AppSettings["FeedBurnerUrl"];
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Tech Forum</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" type="text/css" href="~/Content/bootstrap.css">
    <link rel="stylesheet" type="text/css" href="~/Content/font-awesome.css">
    <link rel="stylesheet" type="text/css" href="~/Content/select2.css">
    <link rel="stylesheet" type="text/css" href="~/Content/jquery.css">
    <link rel="stylesheet" type="text/css" href="~/Content/owl.css">
    <link rel="stylesheet" type="text/css" href="~/Content/jquery-ui.css">
    <link rel="stylesheet" type="text/css" href="~/Content/animate.css">
    <link rel="stylesheet" type="text/css" href="~/Content/reset.css">
    <link rel="stylesheet" type="text/css" href="~/Content/style.css">
    <link rel="stylesheet" type="text/css" href="~/Content/responsive.css">
    <link rel="stylesheet" type="text/css" href="~/Content/option3.css">
    <script src="~/scripts/js" async="" type="text/javascript"></script>
    <script src="~/scripts/fbds.js" async=""></script>
    <script src="~/scripts/gtm.htm" async=""></script>
    <script src="~/scripts/dc.js" async="" type="text/javascript"></script>
    <script type="text/javascript" src="~/scripts/jquery-1.js"></script>
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink("Tech4M", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <li>@Html.ActionLink("Home", "Index", "Home")</li>
                    <li>@Html.ActionLink("About", "About", "Home")</li>
                    <li>@Html.ActionLink("Contact", "Contact", "Home")</li>
                    <li>@Html.ActionLink("Videos", "Index", "Video")</li>
                    <li>@Html.ActionLink("Books", "Index", "Book")</li>
                    <li>@Html.ActionLink("Interview Question", "Index", "InterviewQuestion")</li>
                    <li class="dropdown">
                        <a class="dropdown-toggle" data-toggle="dropdown" href="#">Facebook<b class="caret"></b></a>
                        <ul class="dropdown-menu">
                            <li>@Html.ActionLink("Profile", "Index", "Facebook")</li>
                            <li>@Html.ActionLink("Search", "Index", "FacebookSearch")</li>
                            <li>@Html.ActionLink("Post", "Index", "FacebookPost")</li>
                            <li>@Html.ActionLink("Photo", "Index", "FacebookPhoto")</li>
                            <li>
                                @Html.ActionLink("Real Time Update", "Manage", "FacebookSubscription")
                        </li>
                        <li class="divider"></li>
                        <li>@Html.ActionLink("Revoke", "FB_RevokeAccessToken", "Facebook")</li>
                        <li>@Html.ActionLink("Test API Limit", "FB_TestApiLimit", "Facebook")</li>
                    </ul>
                </li>
            </ul>
            @Html.Partial("_LoginPartial")
        </div>
    </div>
</div>
<div class="container body-content">
    @RenderBody()

    <hr />
    <footer>
        <p>
            <span class="col-xs-6">
                &copy; @DateTime.Now.Year - Tech4M - Tech Forum
            </span>
            @if (ViewBag.GlobalStatusMessage != null)
            {
                <span class="text-danger text-center col-xs-4">@ViewBag.GlobalStatusMessage</span>
            }
        </p>
    </footer>
</div>

@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/bootstrap")
@Scripts.Render("~/bundles/SignalRScripts")
<!--Reference the autogenerated SignalR hub script. -->
<script src="~/signalr/hubs"></script>
@Scripts.Render("~/bundles/CommonFunctions")
@RenderSection("scripts", required: false)
</body>
</html>
