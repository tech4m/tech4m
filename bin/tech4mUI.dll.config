    <add key="Facebook_Distance_Meters" value="16000" />

    <add key="LinkedIn_ClientId" value="75nk3jlrvl8r7o" />
    <add key="LinkedIn_ClientSecret" value="24Xc6dNbw6CiFdgt" />

    <!-- Timezone in which post published date has to be displayed -->
    <add key="Timezone" value="India Standard Time" />
